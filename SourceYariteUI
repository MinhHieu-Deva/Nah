                local function Toggle()
                    Dropdown_1.Visible = not Dropdown_1.Visible
                    if Dropdown_1.Visible then
                        Refresh("")
                        TextBox_1.Text = ""
                    end
                end

                Open.MouseButton1Click:Connect(function()
                    if Library:IsDropdownOpen() and not Dropdown_1.Visible then return end
                    Toggle()
                end)
            end

            return Open
        end

