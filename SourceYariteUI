                    search = search or TextBox_1.Text
                    search = search:lower()

                    for _, opt in pairs(OptionCreated) do
                        opt:Destroy()
                    end
                    table.clear(OptionCreated)

                    for _, item in ipairs(List) do
                        local itemName = tostring(item)
                        if search == "" or itemName:lower():find(search) then
