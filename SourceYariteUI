                local absX = ColorBar_1.AbsolutePosition.X
                local absW = ColorBar_1.AbsoluteSize.X
                local ratio = math.clamp((input.Position.X - absX) / absW, 0, 1)
                return ratio * (Max - Min) + Min
            end

