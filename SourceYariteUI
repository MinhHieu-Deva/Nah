                                Selectable = false
                            })

                            Library:Create("UICorner", {
                                Parent = Highlight,
                                CornerRadius = UDim.new(0, 3)
                            })

                            local Click = Library:Button(Option)

                            Click.MouseButton1Click:Connect(function()
                                if IsMulti then
                                    local found = false
                                    for i, v in ipairs(Value) do
                                        if v == item then
                                            table.remove(Value, i)
                                            found = true
                                            break
                                        end
                                    end
                                    if not found then
                                        table.insert(Value, item)
                                    end
                                    Desc_1.Text = GetText()
                                    Left.Desc.Text = GetText()
                                    Callback(Value)
                                else
                                    Value = item
                                    Desc_1.Text = tostring(Value)
                                    Left.Desc.Text = tostring(Value)
                                    Callback(Value)
                                    Dropdown_1.Visible = false
                                end
                            end)

                            table.insert(OptionCreated, Option)
                        end
